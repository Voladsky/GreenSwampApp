@page
@model ContactModel
@{
    ViewData["Title"] = "Contact";
}

<section class="rounded-xl shadow-sm p-8 max-w-2xl mx-auto my-8">
    <div class="text-center mb-8">
        <h2 class="text-3xl font-bold text-swamp-900 mb-2">Swamp Mail</h2>
        <p class="text-swamp-700">Send a message that'll hop straight to our team</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-6" role="alert">
            <strong class="font-bold">Ribbit!</strong>
            <span class="block sm:inline"> Your message has been sent. We'll hop to it!</span>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-6" role="alert">
            <strong class="font-bold">Error!</strong>
            <span class="block sm:inline"> @TempData["Error"]</span>
        </div>
    }

    <form method="post" class="space-y-6">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-red-600 mb-4"></div>

        <div>
            <label asp-for="Input.Name" class="block text-sm font-medium text-swamp-700 mb-1"></label>
            <input asp-for="Input.Name" class="w-full px-4 py-2 border border-swamp-200 rounded-lg focus:ring-2 focus:ring-swamp-400 focus:border-transparent" placeholder="Viggo The Frogger" />
            <span asp-validation-for="Input.Name" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Input.Email" class="block text-sm font-medium text-swamp-700 mb-1"></label>
            <input asp-for="Input.Email" class="w-full px-4 py-2 border border-swamp-200 rounded-lg focus:ring-2 focus:ring-swamp-400 focus:border-transparent" placeholder="croak@swamp.edu" />
            <span asp-validation-for="Input.Email" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Input.Topic" class="block text-sm font-medium text-swamp-700 mb-1"></label>
            <select asp-for="Input.Topic" class="w-full px-4 py-2 border border-swamp-200 rounded-lg focus:ring-2 focus:ring-swamp-400 focus:border-transparent">
                <option value="">-- Select a topic --</option>
                <option>General Question</option>
                <option>Bug Report</option>
                <option>Feature Request</option>
                <option>Partnership</option>
            </select>
            <span asp-validation-for="Input.Topic" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Input.Message" class="block text-sm font-medium text-swamp-700 mb-1"></label>
            <textarea asp-for="Input.Message" rows="5" class="w-full px-4 py-2 border border-swamp-200 rounded-lg focus:ring-2 focus:ring-swamp-400 focus:border-transparent" placeholder="Type your message here..."></textarea>
            <span asp-validation-for="Input.Message" class="text-red-500 text-sm"></span>
        </div>

        <div class="text-center">
            <button type="submit"
                    class="bg-swamp-500 text-white px-8 py-3 rounded-full font-semibold hover:bg-swamp-600 transition-colors flex items-center justify-center space-x-2 mx-auto shadow-lg hover:shadow-swamp-200/50">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <span>Send Message</span>
            </button>
        </div>
    </form>
</section>

<!-- Success Modal -->
<div id="contactSuccess" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-[100]">
    <div class="bg-white rounded-xl max-w-md w-full p-6 relative shadow-lg">
        <div class="text-center">
            <div class="mx-auto w-24 h-24 bg-swamp-100 rounded-full flex items-center justify-center mb-4">
                <img src="~/images/green-toad-wink.svg" alt="The toad approves" class="w-16 h-16">
            </div>
            <h3 class="text-xl font-bold text-swamp-900 mb-2">Message Sent!</h3>
            <p class="text-swamp-700">We'll hop to it! Expect a response within 24-48 hours.</p>
            <button onclick="closeContactSuccess()"
                    class="mt-6 bg-swamp-500 text-white px-6 py-2 rounded-full hover:bg-swamp-600 transition-colors">
                Ribbitastic!
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        @if (TempData["ShowSuccessModal"] != null)
        {
                <text>showContactSuccess();</text>
        }

        function showContactSuccess() {
            const modal = document.getElementById('contactSuccess');
            if(modal) {
                modal.classList.remove('hidden');
                modal.setAttribute('aria-hidden', 'false');
            }
        }

        function closeContactSuccess() {
            const modal = document.getElementById('contactSuccess');
            if(modal) {
                modal.classList.add('hidden');
                modal.setAttribute('aria-hidden', 'true');
            }
        }

        // Закрытие по клику на фон
        document.addEventListener('click', function(e) {
            const modal = document.getElementById('contactSuccess');
            if(e.target === modal) {
                closeContactSuccess();
            }
        });
    </script>
}