@model GreenSwampApp.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = $"{Model.User.DisplayName} (@@{Model.User.Username}) - Greenswamp";
}
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var antiforgeryToken = Antiforgery.GetAndStoreTokens(Context);
}
<input type="hidden" name="__RequestVerificationToken" value="@antiforgeryToken.RequestToken" />

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
        theme: {
        extend: {
        colors: {
        swamp: {
        50: '#f0fdf4',
        100: '#dcfce7',
        200: '#bbf7d0',
        300: '#86efac',
        400: '#4ade80',
        500: '#22c55e',
        600: '#16a34a',
        700: '#15803d',
        800: '#166534',
        900: '#14532d',
        }
        }
        }
        }
        }
    </script>
</head>
<body class="bg-swamp-50">

    <!-- Main Container -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-0 lg:divide-x sm:divide-y lg:min-h-screen">

            <!-- Left Sidebar -->
            <div class="lg:col-span-1 bg-white order-1">
                @if (User.Identity.IsAuthenticated)
                {
                    @await Component.InvokeAsync("UserSidebar")
                }
                else
                {
                    <div class="p-6 space-y-4">
                        <div class="flex items-center space-x-2">
                            <img src="/images/green-toad-logo.svg" alt="Greenswamp Logo" class="h-8 w-8">
                            <span class="text-2xl font-bold text-swamp-600">Greenswamp</span>
                        </div>
                        <div class="space-x-2">
                            <a href="/register">
                                <button class="bg-swamp-500 font-semibold text-white px-4 py-2 rounded-full hover:bg-swamp-600">Register</button>
                            </a>
                            <a href="/login">
                                <button class="bg-slate-200 font-semibold text-slate-900 px-4 py-2 rounded-full hover:bg-slate-300">Login</button>
                            </a>
                        </div>
                    </div>
                }
            </div>

            <!-- Main Profile Content -->
            <div class="lg:col-span-2 divide-y bg-white order-3">
                <!-- Profile Header -->
                <div class="relative overflow-hidden">
                    <!-- Banner -->
                    <div class="h-48 bg-gradient-to-r from-swamp-800 to-swamp-600 relative">
                        @if (!string.IsNullOrEmpty(Model.User.AvatarUrl))
                        {
                            <img src="@Model.User.AvatarUrl" class="w-full h-full object-cover" alt="Cover">
                        }
                        <div class="absolute inset-0 bg-black bg-opacity-20"></div>

                        <!-- Avatar Container -->
                        <div class="absolute -bottom-12 left-6">
                            <div class="w-32 h-32 rounded-full border-4 border-white bg-swamp-200 overflow-hidden shadow-xl">
                                @if (!string.IsNullOrEmpty(Model.User.AvatarUrl))
                                {
                                    <img src="@Model.User.AvatarUrl" class="w-full h-full object-cover" alt="@Model.User.DisplayName">
                                }
                                else
                                {
                                    <div class="w-full h-full flex items-center justify-center bg-swamp-500 text-white text-4xl">
                                        @Model.User.DisplayName?.FirstOrDefault().ToString().ToUpper()
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Profile Info -->
                    <div class="pt-16 pb-6 px-6">
                        <div class="flex justify-between items-start">
                            <div>
                                <h1 class="text-2xl font-bold text-swamp-900">@Model.User.DisplayName</h1>
                                <p class="text-swamp-500">@@@Model.User.Username</p>
                            </div>
                            
                            @if (User.Identity.IsAuthenticated)
                            {
                                var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                                if (currentUserId == Model.User.UserId.ToString())
                                {
                                    <!-- Current user viewing their own profile - Show Edit Profile button -->
                                    <a href="/settings/profile" class="px-4 py-2 flex items-center space-x-1 bg-swamp-500 text-white rounded-full hover:bg-swamp-600 transition-all">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                        </svg>
                                        <span>Edit Profile</span>
                                    </a>
                                }
                                else
                                {
                                }
                            }
                        </div>

                        <!-- Stats -->
                        <div class="mt-4 flex gap-6 text-swamp-700">
                            <div><span class="font-bold text-swamp-900">@Model.FollowingCount</span> Following</div>
                            <div><span class="font-bold text-swamp-900">@Model.FollowersCount</span> Followers</div>
                        </div>

                        <!-- Bio -->
                        @if (!string.IsNullOrEmpty(Model.Bio))
                        {
                            <div class="mt-4 text-swamp-700 leading-relaxed">
                                @Html.Raw(Model.Bio.Replace("\n", "<br/>"))
                            </div>
                        }
                    </div>

                    <!-- Content Tabs -->
                    <div class="flex border-b border-swamp-200 px-6">
                        <button class="px-4 py-3 text-swamp-700 border-b-2 border-swamp-500 font-medium">Ribbits</button>
                        <button class="px-4 py-3 text-swamp-500 hover:text-swamp-700 font-medium">Replies</button>
                        <button class="px-4 py-3 text-swamp-500 hover:text-swamp-700 font-medium">Media</button>
                        <button class="px-4 py-3 text-swamp-500 hover:text-swamp-700 font-medium">Likes</button>
                    </div>
                </div>

                <!-- Posts Feed -->
                <div class="divide-y divide-swamp-100">
                    @if (Model.Posts != null && Model.Posts.Any())
                    {
                        @foreach (var post in Model.Posts)
                        {
                            <div class="bg-white p-6 hover:bg-swamp-50 transition-colors">
                                <div class="flex items-start space-x-3">
                                    <a href="/profile/@post.User.Username">
                                        <img src="@post.User.AvatarUrl" alt="@post.User.DisplayName" class="w-12 h-12 rounded-full object-cover">
                                    </a>
                                    <div class="flex-1">
                                        <div class="flex items-center space-x-2 flex-wrap">
                                            <a href="/profile/@post.User.Username">
                                                <h4 class="font-semibold text-swamp-900 hover:text-swamp-600">@post.User.DisplayName</h4>
                                            </a>
                                            <a href="/profile/@post.User.Username" class="text-sm text-swamp-500 hover:text-swamp-700">@@@post.User.Username</a>
                                            <span class="text-swamp-300">·</span>
                                            <a href="/feed/post/@post.PostId" class="text-sm text-swamp-500 hover:text-swamp-700">@post.TimeAgo</a>
                                        </div>
                                        
                                        <p class="mt-2 text-swamp-800 whitespace-pre-wrap">
                                            @post.Content
                                        </p>
                                        
                                        @if (!string.IsNullOrEmpty(post.MediaUrl))
                                        {
                                            <div class="mt-3 rounded-lg overflow-hidden">
                                                @if (post.MediaType == "video")
                                                {
                                                    <video class="w-full max-h-96 object-contain bg-black" controls>
                                                        <source src="@post.MediaUrl" type="video/mp4">
                                                        Your browser does not support the video tag.
                                                    </video>
                                                }
                                                else
                                                {
                                                    <img src="@post.MediaUrl" alt="Post media" class="w-full max-h-96 object-contain rounded-lg" />
                                                }
                                            </div>
                                        }
                                        
                                        <div class="mt-4 flex items-center space-x-6 text-swamp-500">
                                            <button class="flex items-center space-x-2 hover:text-swamp-600 transition-colors">
                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                                                </svg>
                                                <span>@post.AnswersCount</span>
                                            </button>
                                            <button class="flex items-center space-x-2 hover:text-swamp-600 transition-colors">
                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                                                </svg>
                                                <span>@post.ReribbsCount</span>
                                            </button>
                                            <button class="flex items-center space-x-2 hover:text-red-600 transition-colors">
                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                                                </svg>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="bg-white p-12 text-center">
                            <div class="text-6xl mb-4">🐸</div>
                            <p class="text-swamp-500 text-lg">No ribbits yet.</p>
                            @if (User.Identity.IsAuthenticated && User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == Model.User.UserId.ToString())
                            {
                                <button onclick="openPostModal()" class="mt-4 bg-swamp-500 text-white px-6 py-2 rounded-full hover:bg-swamp-600">
                                    Create your first ribbit
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Right Sidebar -->
            <div class="lg:col-span-1 bg-white order-2 lg:order-4">
                <!-- Search -->
                <div class="p-6 pb-0">
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="w-5 h-5 text-swamp-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                            </svg>
                        </div>
                        <input type="text"
                               placeholder="Search"
                               class="w-full pl-10 pr-4 py-2 bg-swamp-100 rounded-full border-none focus:ring-2 focus:ring-swamp-400 focus:outline-none placeholder:text-swamp-400">
                    </div>
                </div>

                <!-- Trending Ponds -->
                @if (Model.TrendingTags != null && Model.TrendingTags.Any())
                {
                    <div class="p-6 pb-0">
                        <h3 class="text-lg font-semibold text-swamp-900 mb-4">Trending Ponds</h3>
                        <ul class="space-y-4">
                            @foreach (var tag in Model.TrendingTags.Take(5))
                            {
                                <li>
                                    <a href="/ponds/@tag.Name" class="flex items-center space-x-3 group">
                                        <div class="w-10 h-10 bg-swamp-100 rounded-lg flex items-center justify-center group-hover:bg-swamp-200 transition-colors">
                                            <span class="text-swamp-600 text-lg">#</span>
                                        </div>
                                        <div>
                                            <h4 class="font-medium text-swamp-900 group-hover:text-swamp-600">#@tag.Name</h4>
                                            <p class="text-sm text-swamp-500">@tag.PostCount posts</p>
                                        </div>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                }

                <!-- Footer Links -->
                <div class="p-6 text-xs text-swamp-500">
                    <div class="flex flex-wrap gap-x-3 gap-y-1">
                        <a href="#" class="hover:text-swamp-700">About</a>
                        <span>·</span>
                        <a href="#" class="hover:text-swamp-700">Help Center</a>
                        <span>·</span>
                        <a href="/privacy" class="hover:text-swamp-700">Privacy</a>
                        <span>·</span>
                        <a href="/tos" class="hover:text-swamp-700">Terms</a>
                    </div>
                    <p class="mt-3">© 2024 Greenswamp</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Post Modal -->
    <!-- Post Modal -->
    <div id="postModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
        <div class="bg-white rounded-xl max-w-2xl w-full p-6">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-xl font-semibold">New Ribbit</h3>
                <button onclick="closePostModal()" class="text-swamp-500 hover:text-swamp-700 text-2xl leading-none">&times;</button>
            </div>
            <textarea id="postContent"
                      class="w-full p-4 border border-swamp-200 rounded-lg focus:ring-2 focus:ring-swamp-400 focus:border-transparent"
                      rows="4"
                      placeholder="What's hopping?"></textarea>
            <div class="mt-4 flex justify-between items-center">
                <div class="space-x-2">
                    <button type="button" class="p-2 hover:bg-swamp-100 rounded-lg" onclick="insertFrogmoji()">🐸 Add Frogmoji</button>
                </div>
                <button id="sendRibbitBtn"
                        class="bg-swamp-500 text-white px-6 py-2 rounded-full hover:bg-swamp-600 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                    Send Ribbit
                </button>
            </div>
            <div id="postError" class="mt-3 text-red-600 text-sm hidden"></div>
        </div>
    </div>

    <script>
        // Get CSRF token from the anti-forgery cookie (ASP.NET Core)
        function getCsrfToken() {
        const cookieValue = document.cookie
        .split('; ')
        .find(row => row.startsWith('__RequestVerificationToken='));
        return cookieValue ? cookieValue.split('=')[1] : null;
        }

        async function createPost(content) {
        const token = getCsrfToken();
        const response = await fetch('/api/posts', {
        method: 'POST',
        headers: {
        'Content-Type': 'application/json',
        'RequestVerificationToken': token || ''
        },
        body: JSON.stringify({ content: content })
        });

        if (!response.ok) {
        const errorData = await response.json().catch(() => ({ message: 'Failed to create post' }));
        throw new Error(errorData.message || `Server error: ${response.status}`);
        }
        return await response.json();
        }

        // Insert a random frogmoji or emoji list
        function insertFrogmoji() {
        const textarea = document.getElementById('postContent');
        const emojis = ['🐸', '🐸✨', '🐸💚', '🐸🌿', '🐸📢', '🐸🎤', '🐸👑', '🐸🔥'];
        const randomEmoji = emojis[Math.floor(Math.random() * emojis.length)];
        const start = textarea.selectionStart;
        const end = textarea.selectionEnd;
        const text = textarea.value;
        textarea.value = text.substring(0, start) + randomEmoji + text.substring(end);
        textarea.focus();
        textarea.selectionStart = textarea.selectionEnd = start + randomEmoji.length;
        }

        // Main submit handler
        document.getElementById('sendRibbitBtn').addEventListener('click', async () => {
        const textarea = document.getElementById('postContent');
        const content = textarea.value.trim();
        const errorDiv = document.getElementById('postError');
        const sendBtn = document.getElementById('sendRibbitBtn');

        if (!content) {
        errorDiv.textContent = 'Please write something before ribbiting!';
        errorDiv.classList.remove('hidden');
        return;
        }

        // Disable button, show loading
        sendBtn.disabled = true;
        sendBtn.textContent = 'Sending...';
        errorDiv.classList.add('hidden');

        try {
        await createPost(content);
        // Success – close modal, clear text, optionally reload feed
        closePostModal();
        textarea.value = '';
        // Reload the feed to show the new post (or optionally append it dynamically)
        window.location.reload();
        } catch (err) {
        errorDiv.textContent = err.message || 'An error occurred. Please try again.';
        errorDiv.classList.remove('hidden');
        } finally {
        sendBtn.disabled = false;
        sendBtn.textContent = 'Send Ribbit';
        }
        });

        // Allow Ctrl+Enter to submit
        document.getElementById('postContent').addEventListener('keydown', (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
        e.preventDefault();
        document.getElementById('sendRibbitBtn').click();
        }
        });

        // Clear error when typing
        document.getElementById('postContent').addEventListener('input', () => {
        document.getElementById('postError').classList.add('hidden');
        });
    </script>

    <script>
        function openPostModal() {
        document.getElementById('postModal').classList.remove('hidden');
        }

        function closePostModal() {
        document.getElementById('postModal').classList.add('hidden');
        }

        function toggleFollow(userId) {
        // Implement follow/unfollow logic here
        fetch(`/api/follow/${userId}`, {
        method: 'POST',
        headers: {
        'Content-Type': 'application/json',
        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
        }
        })
        .then(response => response.json())
        .then(data => {
        if (data.success) {
        location.reload();
        }
        })
        .catch(error => console.error('Error:', error));
        }

        // Close modal when clicking outside
        document.getElementById('postModal')?.addEventListener('click', function(e) {
        if (e.target === this) {
        closePostModal();
        }
        });
    </script>
</body>
</html>