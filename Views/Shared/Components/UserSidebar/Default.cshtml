@model GreenSwampApp.ViewComponents.UserSidebarViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@if (Model == null || Model.User == null)
{
    <div class="p-4 text-red-500">
        Unable to load user data. Please try refreshing the page.
    </div>
}
else
{
    <div class="p-6 pb-0">
        <div class="flex space-x-3">
            <img src="@Model.User.AvatarUrl"
                 alt="@Model.User.DisplayName"
                 class="w-16 h-16 rounded-full object-cover"
                 onerror="this.src='/images/default-avatar.jpg'">
            <div class="flex-1">
                <div class="flex items-center justify-between">
                    <div class="space-y-1">
                        <div class="flex items-center space-x-2">
                            <h4 class="font-semibold text-swamp-900">@Model.User.DisplayName</h4>
                            <div class="relative">
                                <button id="settingsButton"
                                        class="text-swamp-700 hover:text-swamp-700 transition-colors"
                                        aria-label="Profile settings"
                                        aria-haspopup="true">
                                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                                        <circle cx="18" cy="12" r="1.5" transform="rotate(90 18 12)"></circle>
                                        <circle cx="12" cy="12" r="1.5" transform="rotate(90 12 12)"></circle>
                                        <circle cx="6" cy="12" r="1.5" transform="rotate(90 6 12)"></circle>
                                    </svg>
                                </button>
                                <div id="settingsDropdown"
                                     class="absolute hidden right-0 mt-2 w-48 bg-white rounded-lg shadow-xl border border-swamp-100 z-50">
                                    <div class="py-1">
                                        <a href="/settings" class="w-full px-4 py-2 text-sm text-swamp-700 hover:bg-swamp-50 flex items-center space-x-2">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                            </svg>
                                            <span>Settings</span>
                                        </a>
                                        <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                            <button type="submit" class="w-full px-4 py-2 text-sm text-swamp-700 hover:bg-swamp-50 flex items-center space-x-2">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                                                </svg>
                                                <span>Sign Out</span>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <a href="/profile/@Model.User.Username" class="text-sm text-swamp-500 hover:text-swamp-700">@@@Model.User.Username</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="p-6 space-y-4">
        <!-- Stats -->
        <div class="flex justify-around py-2 border-y border-swamp-100">
            <div class="text-center">
                <div class="font-bold text-swamp-900">@Model.FollowingCount</div>
                <div class="text-xs text-swamp-500">Following</div>
            </div>
            <div class="text-center">
                <div class="font-bold text-swamp-900">@Model.FollowersCount</div>
                <div class="text-xs text-swamp-500">Followers</div>
            </div>
        </div>

        <!-- New Ribbit Button -->
        <button class="w-full flex items-center justify-center bg-swamp-500 text-white space-x-2 p-2 px-4 rounded-full hover:bg-swamp-600 transition-colors" onclick="window.openPostModal ? window.openPostModal() : alert('Post modal function not available')">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 14V22H2.99997V4H13"></path>
                <path d="M17.4608 4.03921C18.2418 3.25817 19.5082 3.25816 20.2892 4.03921L20.9608 4.71079C21.7418 5.49184 21.7418 6.75817 20.9608 7.53921L11.5858 16.9142C11.2107 17.2893 10.702 17.5 10.1716 17.5L7.5 17.5L7.5 14.8284C7.5 14.298 7.71071 13.7893 8.08579 13.4142L17.4608 4.03921Z"></path>
                <path d="M16.25 5.25L19.75 8.75"></path>
            </svg>
            <span>New Ribbit</span>
        </button>

        <!-- Navigation Links -->
        <a href="/feed" class="p-1 text-swamp-900 flex items-center space-x-2 hover:bg-swamp-50 rounded-lg transition-colors">
            <svg class="w-8 h-8" fill="currentColor" viewBox="-81.92 -81.92 675.84 675.84">
                <path d="M163.575,120.725c-5.855,0-10.601,4.747-10.601,10.601c0,6.132-4.993,11.12-11.131,11.12 c-6.132,0-11.121-4.988-11.121-11.12c0-5.854-4.746-10.601-10.601-10.601s-10.601,4.747-10.601,10.601 c0,17.823,14.501,32.323,32.324,32.323c17.829,0,32.334-14.501,32.334-32.323C174.177,125.472,169.431,120.725,163.575,120.725z" />
                <path d="M392.821,120.725c-5.855,0-10.601,4.747-10.601,10.601c0,6.132-4.993,11.12-11.131,11.12 c-6.132,0-11.121-4.988-11.121-11.12c0-5.854-4.746-10.601-10.601-10.601s-10.601,4.747-10.601,10.601 c0,17.823,14.501,32.323,32.324,32.323c17.829,0,32.334-14.501,32.334-32.323C403.422,125.472,398.676,120.725,392.821,120.725z" />
            </svg>
            <h3 class="text-lg font-semibold">Swamp</h3>
        </a>

        <a href="/events" class="p-1 text-swamp-900 flex items-center space-x-2 hover:bg-swamp-50 rounded-lg transition-colors">
            <svg class="w-8 h-8" fill="currentColor" viewBox="-43.32 -43.32 327.29 327.29">
                <path d="m218.787,119.069c-7.552-18.233-23.021-35.615-43.56-48.944-5.611-3.642-11.369-6.826-17.027-9.48 0.001-0.074 0.005-0.148 0.005-0.222 0-15.537-9.405-28.913-22.818-34.749l12.87-12.87c2.929-2.929 2.929-7.678 0-10.606-2.93-2.929-7.678-2.929-10.607,0l-17.237,17.237-17.068-17.068c-2.93-2.929-7.678-2.929-10.607-8.88178e-16-2.929,2.929-2.929,7.678 0,10.606l12.644,12.644c-13.478,5.809-22.94,19.221-22.94,34.805 0,0.074 0.004,0.148 0.005,0.223-5.659,2.654-11.417,5.839-17.029,9.481-20.537,13.329-36.006,30.711-43.558,48.943-8.021,19.364 1.207,41.645 20.573,49.667 4.648,1.925 9.538,2.901 14.534,2.901 6.008-0.001 11.758-1.412 16.9-3.96 9.77,16.056 27.176,26.038 46.456,26.038 19.279,0 36.686-9.981 46.456-26.036 5.142,2.546 10.893,3.958 16.901,3.958 4.996,0 9.886-0.976 14.534-2.901 19.366-8.022 28.595-30.303 20.573-49.667z" />
            </svg>
            <h3 class="text-lg font-semibold">Events</h3>
        </a>

        <a href="/ponds" class="p-1 text-swamp-900 flex items-center space-x-2 hover:bg-swamp-50 rounded-lg transition-colors">
            <svg class="w-8 h-8" fill="currentColor" viewBox="-122.88 -122.88 757.76 757.76">
                <path d="M452.09,335.122c62.386-69.965,60.006-177.603,59.867-182.309c-0.255-8.712-7.161-15.767-15.864-16.21 c-2.307-0.116-34.685-1.557-74.997,6.427c-7.934-39.686-21.397-68.089-22.046-69.442c-3.695-7.715-12.621-11.393-20.681-8.529 c-1.409,0.502-30.793,11.089-64.301,33.391c-22.136-33.013-45.055-53.88-46.902-55.536c-6.353-5.7-15.98-5.7-22.333,0 c-1.847,1.658-24.767,22.523-46.902,55.536c-33.507-22.302-62.891-32.891-64.3-33.392c-8.061-2.866-16.983,0.815-20.681,8.529 c-0.649,1.353-14.111,29.756-22.046,69.442c-40.312-7.986-72.689-6.543-74.996-6.426c-8.706,0.441-15.61,7.497-15.865,16.21 c-0.138,4.706-2.518,112.345,59.867,182.309c-25.548,10.116-54.712,27.242-54.712,54.639c0,26.751,27.147,48.071,80.688,63.368 c45.665,13.047,106.079,20.232,170.114,20.232c64.035,0,124.449-7.185,170.114-20.232c53.54-15.297,80.688-36.617,80.688-63.368 C506.802,362.378,477.675,345.252,452.09,335.122z" />
            </svg>
            <h3 class="text-lg font-semibold">Ponds</h3>
        </a>

        @if (Model.TrendingTags != null && Model.TrendingTags.Any())
        {
            <div class="pt-2">
                <h4 class="text-sm font-semibold text-swamp-600 mb-2">TRENDING PONDS</h4>
                <ul class="space-y-2">
                    @foreach (var tag in Model.TrendingTags)
                    {
                        <li>
                            <a href="/ponds/@tag.Name" class="flex items-center space-x-2 text-sm text-swamp-700 hover:text-swamp-900 hover:bg-swamp-50 p-1 rounded transition-colors">
                                <span class="w-2 h-2 bg-swamp-400 rounded-full"></span>
                                <span>#@tag.Name</span>
                                <span class="text-xs text-swamp-400">(@tag.PostCount)</span>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        }
    </div>

    <script>
        (function() {
            // Wait for DOM to be fully loaded
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initDropdown);
            } else {
                initDropdown();
            }

            function initDropdown() {
                const btn = document.getElementById('settingsButton');
                const dropdown = document.getElementById('settingsDropdown');
                
                if (!btn || !dropdown) {
                    console.warn('Settings button or dropdown not found');
                    return;
                }

                let isOpen = false;

                function toggleDropdown() {
                    isOpen = !isOpen;
                    dropdown.classList.toggle('hidden', !isOpen);
                    btn.setAttribute('aria-expanded', isOpen);
                }

                function closeDropdown() {
                    isOpen = false;
                    dropdown.classList.add('hidden');
                    btn.setAttribute('aria-expanded', 'false');
                }

                btn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    toggleDropdown();
                });

                document.addEventListener('click', (e) => {
                    if (dropdown && !dropdown.contains(e.target) && btn && !btn.contains(e.target)) {
                        closeDropdown();
                    }
                });

                document.addEventListener('keydown', (e) => {
                    if (e.key === 'Escape') closeDropdown();
                });
            }
        })();
    </script>
}