@{
    ViewData["Title"] = $"#{ViewBag.CurrentTag} - Greenswamp Ponds";
    var posts = ViewBag.Posts as IEnumerable<GreenSwampApp.ViewModels.PostViewModel>;
    var trendingTags = ViewBag.TrendingTags as IEnumerable<GreenSwampApp.ViewModels.TrendingTagViewModel>;
    var currentTag = ViewBag.CurrentTag as string;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        swamp: {
                            50: '#f0fdf4',
                            100: '#dcfce7',
                            200: '#bbf7d0',
                            300: '#86efac',
                            400: '#4ade80',
                            500: '#22c55e',
                            600: '#16a34a',
                            700: '#15803d',
                            800: '#166534',
                            900: '#14532d',
                        }
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-swamp-50">

    <!-- Main Feed Container -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-0 lg:divide-x sm:divide-y lg:h-[calc(100vb-4rem)]">

            <!-- Left Sidebar -->
            <div class="lg:col-span-1 bg-white order-1">
                <div class="p-6 space-y-4">
                    <div class="flex items-center space-x-2">
                        <img src="/images/green-toad-logo.svg" alt="Greenswamp Logo" class="h-8 w-8">
                        <span class="text-2xl font-bold text-swamp-600">Greenswamp</span>
                    </div>
                    <div class="space-x-2">
                        <a href="/register">
                            <button class="bg-swamp-500 font-semibold text-white px-4 py-2 rounded-full hover:bg-swamp-600">
                                Register
                            </button>
                        </a>
                        <a href="/login">
                            <button class="bg-slate-200 font-semibold text-slate-900 px-4 py-2 rounded-full hover:bg-slate-300">
                                Login
                            </button>
                        </a>
                    </div>
                </div>

                <!-- Quick Links -->
                <div class="px-6 pb-6 space-y-2">
                    <a href="/feed" class="p-1 text-swamp-900 flex items-center space-x-2 hover:bg-swamp-50 rounded-lg">
                        <svg class="w-8 h-8" fill="currentColor" stroke="currentColor" viewBox="-81.92 -81.92 675.84 675.84" stroke-width="0.0">
                            <g>
                                <path d="M163.575,120.725c-5.855,0-10.601,4.747-10.601,10.601c0,6.132-4.993,11.12-11.131,11.12 c-6.132,0-11.121-4.988-11.121-11.12c0-5.854-4.746-10.601-10.601-10.601s-10.601,4.747-10.601,10.601 c0,17.823,14.501,32.323,32.324,32.323c17.829,0,32.334-14.501,32.334-32.323C174.177,125.472,169.431,120.725,163.575,120.725z" />
                            </g>
                        </svg>
                        <h3 class="text-lg font-semibold">Swamp</h3>
                    </a>
                    <a href="#" class="p-1 text-swamp-900 flex items-center space-x-2 hover:bg-swamp-50 rounded-lg">
                        <svg class="w-8 h-8" fill="currentColor" stroke="currentColor" viewBox="-43.32 -43.32 327.29 327.29">
                            <path d="m218.787,119.069c-7.552-18.233-23.021-35.615-43.56-48.944-5.611-3.642-11.369-6.826-17.027-9.48 0.001-0.074 0.005-0.148 0.005-0.222 0-15.537-9.405-28.913-22.818-34.749l12.87-12.87c2.929-2.929 2.929-7.678 0-10.606-2.93-2.929-7.678-2.929-10.607,0l-17.237,17.237-17.068-17.068c-2.93-2.929-7.678-2.929-10.607-8.88178e-16-2.929,2.929-2.929,7.678 0,10.606l12.644,12.644c-13.478,5.809-22.94,19.221-22.94,34.805 0,0.074 0.004,0.148 0.005,0.223-5.659,2.654-11.417,5.839-17.029,9.481-20.537,13.329-36.006,30.711-43.558,48.943-8.021,19.364 1.207,41.645 20.573,49.667 4.648,1.925 9.538,2.901 14.534,2.901 6.008-0.001 11.758-1.412 16.9-3.96 9.77,16.056 27.176,26.038 46.456,26.038 19.279,0 36.686-9.981 46.456-26.036 5.142,2.546 10.893,3.958 16.901,3.958 4.996,0 9.886-0.976 14.534-2.901 19.366-8.022 28.595-30.303 20.573-49.667z" />
                        </svg>
                        <h3 class="text-lg font-semibold">Events</h3>
                    </a>
                    <a href="#" class="p-1 text-swamp-900 flex items-center space-x-2 hover:bg-swamp-50 rounded-lg bg-swamp-50">
                        <svg class="w-8 h-8" fill="currentColor" viewBox="-122.88 -122.88 757.76 757.76" stroke-width="0.0">
                            <path d="M452.09,335.122c62.386-69.965,60.006-177.603,59.867-182.309c-0.255-8.712-7.161-15.767-15.864-16.21 c-2.307-0.116-34.685-1.557-74.997,6.427c-7.934-39.686-21.397-68.089-22.046-69.442c-3.695-7.715-12.621-11.393-20.681-8.529 c-1.409,0.502-30.793,11.089-64.301,33.391c-22.136-33.013-45.055-53.88-46.902-55.536c-6.353-5.7-15.98-5.7-22.333,0 c-1.847,1.658-24.767,22.523-46.902,55.536c-33.507-22.302-62.891-32.891-64.3-33.392c-8.061-2.866-16.983,0.815-20.681,8.529 c-0.649,1.353-14.111,29.756-22.046,69.442c-40.312-7.986-72.689-6.543-74.996-6.426c-8.706,0.441-15.61,7.497-15.865,16.21 c-0.138,4.706-2.518,112.345,59.867,182.309c-25.548,10.116-54.712,27.242-54.712,54.639c0,26.751,27.147,48.071,80.688,63.368 c45.665,13.047,106.079,20.232,170.114,20.232c64.035,0,124.449-7.185,170.114-20.232c53.54-15.297,80.688-36.617,80.688-63.368 C506.802,362.378,477.675,345.252,452.09,335.122z" />
                        </svg>
                        <h3 class="text-lg font-semibold">Ponds</h3>
                    </a>
                </div>
            </div>

            <!-- Main Feed - Pond Header and Posts -->
            <div class="lg:col-span-2 divide-y order-3 bg-white">

                <!-- Pond Header -->
                <div class="bg-white p-6 border-b border-swamp-200">
                    <div class="flex items-center space-x-3">
                        <div class="w-12 h-12 bg-swamp-100 rounded-full flex items-center justify-center">
                            <svg class="text-swamp-600 w-7 h-7" fill="currentColor" viewBox="-122.88 -122.88 757.76 757.76">
                                <path d="M452.09,335.122c62.386-69.965,60.006-177.603,59.867-182.309c-0.255-8.712-7.161-15.767-15.864-16.21 c-2.307-0.116-34.685-1.557-74.997,6.427c-7.934-39.686-21.397-68.089-22.046-69.442c-3.695-7.715-12.621-11.393-20.681-8.529 c-1.409,0.502-30.793,11.089-64.301,33.391c-22.136-33.013-45.055-53.88-46.902-55.536c-6.353-5.7-15.98-5.7-22.333,0 c-1.847,1.658-24.767,22.523-46.902,55.536c-33.507-22.302-62.891-32.891-64.3-33.392c-8.061-2.866-16.983,0.815-20.681,8.529 c-0.649,1.353-14.111,29.756-22.046,69.442c-40.312-7.986-72.689-6.543-74.996-6.426c-8.706,0.441-15.61,7.497-15.865,16.21 c-0.138,4.706-2.518,112.345,59.867,182.309c-25.548,10.116-54.712,27.242-54.712,54.639c0,26.751,27.147,48.071,80.688,63.368 c45.665,13.047,106.079,20.232,170.114,20.232c64.035,0,124.449-7.185,170.114-20.232c53.54-15.297,80.688-36.617,80.688-63.368 C506.802,362.378,477.675,345.252,452.09,335.122z" />
                            </svg>
                        </div>
                        <div>
                            <h2 class="text-2xl font-bold text-swamp-900">#@currentTag</h2>
                            <p class="text-swamp-500">@(posts?.Count() ?? 0) ribbits in this pond</p>
                        </div>
                    </div>
                    <div class="mt-4 flex items-center space-x-2">
                        <button class="bg-swamp-500 text-white px-6 py-2 rounded-full text-sm font-medium hover:bg-swamp-600 transition-all">
                            Follow Pond
                        </button>
                        <button class="text-swamp-600 hover:text-swamp-800 text-sm px-4 py-2">
                            Share
                        </button>
                    </div>
                </div>

                <!-- Posts Feed -->
                @if (posts != null && posts.Any())
                {
                    @foreach (var post in posts)
                    {
                        <div class="bg-white p-6 hover:bg-swamp-50/30 transition-colors">
                            <div class="flex items-start space-x-3">
                                <img src="@post.User.AvatarUrl" alt="@post.User.DisplayName" class="w-12 h-12 rounded-full">
                                <div class="flex-1">
                                    <div class="flex items-center space-x-2">
                                        <h4 class="font-semibold text-swamp-900">@post.User.DisplayName</h4>
                                        <a href="/profile/@post.User.Username" class="text-sm text-swamp-500 hover:text-swamp-700">@@@post.User.Username</a>
                                        <span class="text-swamp-500">·</span>
                                        <a href="/feed/post/@post.PostId" class="text-sm text-swamp-500 hover:text-swamp-700">@post.TimeAgo</a>
                                    </div>
                                    <p class="mt-2 text-swamp-700">
                                        @Html.Raw(post.Content)
                                    </p>
                                    @if (!string.IsNullOrEmpty(post.MediaUrl))
                                    {
                                        <div class="mt-4 rounded-lg overflow-hidden border border-swamp-200">
                                            @if (post.MediaType == "video")
                                            {
                                                <video class="w-full aspect-video object-cover bg-slate-900" controls>
                                                    <source src="@post.MediaUrl" type="video/mp4">
                                                </video>
                                            }
                                            else
                                            {
                                                <img src="@post.MediaUrl" alt="Post media" class="w-full object-cover" />
                                            }
                                        </div>
                                    }

                                    <!-- Tags Display -->
                                    @if (post.Tags != null && post.Tags.Any())
                                    {
                                        <div class="mt-3 flex flex-wrap gap-2">
                                            @foreach (var tag in post.Tags)
                                            {
                                                <a href="/ponds/@tag.Name"
                                                   class="text-sm @(tag.Name == currentTag ? "bg-swamp-200 text-swamp-800" : "text-swamp-600 hover:text-swamp-800") px-2 py-1 rounded-full">
                                                    #@tag.Name
                                                </a>
                                            }
                                        </div>
                                    }

                                    <div class="mt-4 flex items-center space-x-6 text-swamp-500">
                                        <a href="/feed/post/@post.PostId" class="flex items-center space-x-2 hover:text-swamp-600">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                                            </svg>
                                            <span>@post.AnswersCount Answers</span>
                                        </a>
                                        <button class="flex items-center space-x-2 hover:text-swamp-600">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                                            </svg>
                                            <span>@post.ReribbsCount Reribbs</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="bg-white p-12 text-center">
                        <div class="w-16 h-16 bg-swamp-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <svg class="text-swamp-500 w-8 h-8" fill="currentColor" viewBox="-122.88 -122.88 757.76 757.76">
                                <path d="M452.09,335.122c62.386-69.965,60.006-177.603,59.867-182.309c-0.255-8.712-7.161-15.767-15.864-16.21 c-2.307-0.116-34.685-1.557-74.997,6.427c-7.934-39.686-21.397-68.089-22.046-69.442c-3.695-7.715-12.621-11.393-20.681-8.529 c-1.409,0.502-30.793,11.089-64.301,33.391c-22.136-33.013-45.055-53.88-46.902-55.536c-6.353-5.7-15.98-5.7-22.333,0 c-1.847,1.658-24.767,22.523-46.902,55.536c-33.507-22.302-62.891-32.891-64.3-33.392c-8.061-2.866-16.983,0.815-20.681,8.529 c-0.649,1.353-14.111,29.756-22.046,69.442c-40.312-7.986-72.689-6.543-74.996-6.426c-8.706,0.441-15.61,7.497-15.865,16.21 c-0.138,4.706-2.518,112.345,59.867,182.309c-25.548,10.116-54.712,27.242-54.712,54.639c0,26.751,27.147,48.071,80.688,63.368 c45.665,13.047,106.079,20.232,170.114,20.232c64.035,0,124.449-7.185,170.114-20.232c53.54-15.297,80.688-36.617,80.688-63.368 C506.802,362.378,477.675,345.252,452.09,335.122z" />
                            </svg>
                        </div>
                        <h3 class="text-lg font-semibold text-swamp-900 mb-2">No ribbits in this pond yet</h3>
                        <p class="text-swamp-500 mb-6">Be the first to make a splash! 🐸</p>
                        <button onclick="openPostModal()" class="bg-swamp-500 text-white px-6 py-2 rounded-full hover:bg-swamp-600 transition-all">
                            Create a Ribbit with #@currentTag
                        </button>
                    </div>
                }
            </div>

            <!-- Right Sidebar -->
            <div class="lg:col-span-1 bg-white order-2 lg:order-4">
                <!-- Search-->
                <div class="p-6 pb-0">
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="w-5 h-5 text-swamp-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                            </svg>
                        </div>
                        <input type="text"
                               placeholder="Search ponds..."
                               class="w-full pl-10 pr-4 py-2 bg-swamp-100 rounded-full border-none focus:ring-2 focus:ring-swamp-400 focus-visible:ring-swamp-400 placeholder:text-swamp-600">
                    </div>
                </div>

                <!-- Trending Ponds -->
                <div class="p-6 pb-0">
                    <h3 class="text-lg font-semibold text-swamp-900 mb-4">Trending Ponds</h3>
                    <ul class="space-y-4">
                        @if (trendingTags != null)
                        {
                            @foreach (var tag in trendingTags)
                            {
                                <li>
                                    <a href="/ponds/@tag.Name"
                                       class="flex items-center space-x-3 group @(tag.Name == currentTag ? "bg-swamp-50 p-2 rounded-lg -mx-2" : "")">
                                        <div class="w-8 h-8 bg-swamp-100 rounded-lg flex items-center justify-center">
                                            <svg class="text-swamp-600 w-5 h-5" fill="currentColor" viewBox="-122.88 -122.88 757.76 757.76">
                                                <path d="M452.09,335.122c62.386-69.965,60.006-177.603,59.867-182.309c-0.255-8.712-7.161-15.767-15.864-16.21 c-2.307-0.116-34.685-1.557-74.997,6.427c-7.934-39.686-21.397-68.089-22.046-69.442c-3.695-7.715-12.621-11.393-20.681-8.529 c-1.409,0.502-30.793,11.089-64.301,33.391c-22.136-33.013-45.055-53.88-46.902-55.536c-6.353-5.7-15.98-5.7-22.333,0 c-1.847,1.658-24.767,22.523-46.902,55.536c-33.507-22.302-62.891-32.891-64.3-33.392c-8.061-2.866-16.983,0.815-20.681,8.529 c-0.649,1.353-14.111,29.756-22.046,69.442c-40.312-7.986-72.689-6.543-74.996-6.426c-8.706,0.441-15.61,7.497-15.865,16.21 c-0.138,4.706-2.518,112.345,59.867,182.309c-25.548,10.116-54.712,27.242-54.712,54.639c0,26.751,27.147,48.071,80.688,63.368 c45.665,13.047,106.079,20.232,170.114,20.232c64.035,0,124.449-7.185,170.114-20.232c53.54-15.297,80.688-36.617,80.688-63.368 C506.802,362.378,477.675,345.252,452.09,335.122z" />
                                            </svg>
                                        </div>
                                        <div>
                                            <h4 class="font-medium @(tag.Name == currentTag ? "text-swamp-700" : "text-swamp-900") group-hover:text-swamp-600">
                                                #@tag.Name
                                            </h4>
                                            <p class="text-sm text-swamp-500">@tag.PostCount posts</p>
                                        </div>
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                </div>

                <!-- Related Ponds -->
                <div class="p-6 pb-0">
                    <h3 class="text-lg font-semibold text-swamp-900 mb-4">You might like</h3>
                    <ul class="space-y-3">
                        <li>
                            <a href="/ponds/SwampLife" class="flex items-center space-x-3 group">
                                <div class="w-8 h-8 bg-swamp-100 rounded-lg flex items-center justify-center">
                                    <span class="text-swamp-600 text-lg font-bold">#</span>
                                </div>
                                <div>
                                    <h4 class="font-medium text-swamp-900 group-hover:text-swamp-600">#SwampLife</h4>
                                    <p class="text-sm text-swamp-500">Daily swamp vibes</p>
                                </div>
                            </a>
                        </li>
                        <li>
                            <a href="/ponds/FrogFam" class="flex items-center space-x-3 group">
                                <div class="w-8 h-8 bg-swamp-100 rounded-lg flex items-center justify-center">
                                    <span class="text-swamp-600 text-lg font-bold">#</span>
                                </div>
                                <div>
                                    <h4 class="font-medium text-swamp-900 group-hover:text-swamp-600">#FrogFam</h4>
                                    <p class="text-sm text-swamp-500">Family of frogs</p>
                                </div>
                            </a>
                        </li>
                        <li>
                            <a href="/ponds/CyberSwamp" class="flex items-center space-x-3 group">
                                <div class="w-8 h-8 bg-swamp-100 rounded-lg flex items-center justify-center">
                                    <span class="text-swamp-600 text-lg font-bold">#</span>
                                </div>
                                <div>
                                    <h4 class="font-medium text-swamp-900 group-hover:text-swamp-600">#CyberSwamp</h4>
                                    <p class="text-sm text-swamp-500">Future of swamps</p>
                                </div>
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- Footer -->
                <div class="p-6">
                    <div class="flex items-start space-x-2 text-swamp-600 text-sm">
                        <a href="#" class="hover:text-swamp-800">Contact</a>
                        <span>•</span>
                        <a href="/privacy" class="hover:text-swamp-800">Privacy</a>
                        <span>•</span>
                        <a href="/tos" class="hover:text-swamp-800">Terms</a>
                    </div>
                    <p class="text-xs text-swamp-400 mt-4">© 2024 Greenswamp · All rights reserved</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Post Modal -->
    <div id="postModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
        <div class="bg-white rounded-xl max-w-2xl w-full p-6">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-xl font-semibold">New Ribbit</h3>
                <button onclick="closePostModal()" class="text-swamp-500 hover:text-swamp-700">
                    ✕
                </button>
            </div>
            <div class="mb-4">
                <span class="inline-block bg-swamp-100 text-swamp-700 px-3 py-1 rounded-full text-sm">
                    #@currentTag
                </span>
            </div>
            <textarea class="w-full p-4 border border-swamp-200 rounded-lg focus:ring-2 focus:ring-swamp-400 focus:border-transparent"
                      rows="4"
                      placeholder="What's hopping?">#@currentTag </textarea>
            <div class="mt-4 flex justify-between items-center">
                <div class="space-x-2">
                    <button class="p-2 hover:bg-swamp-100 rounded-lg">
                        🐸 Add Frogmoji
                    </button>
                </div>
                <button class="bg-swamp-500 text-white px-6 py-2 rounded-full hover:bg-swamp-600">
                    Send Ribbit
                </button>
            </div>
        </div>
    </div>

    <script>
        function openPostModal() {
            document.getElementById('postModal').classList.remove('hidden');
        }

        function closePostModal() {
            document.getElementById('postModal').classList.add('hidden');
        }
    </script>
</body>
</html>