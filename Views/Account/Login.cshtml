@model GreenSwampApp.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Login - Greenswamp";
}

@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
        theme: {
        extend: {
        colors: {
        swamp: {
        50: '#f0fdf4',
        100: '#dcfce7',
        200: '#bbf7d0',
        300: '#86efac',
        400: '#4ade80',
        500: '#22c55e',
        600: '#16a34a',
        700: '#15803d',
        800: '#166534',
        900: '#14532d',
        }
        }
        }
        }
        }
    </script>
    <style>
        .swamp-bg {
        background-image: url('istockphoto-1464399789-1024x1024.jpg');
        background-repeat: repeat-x;
        background-size: auto 100%;
        background-position: center top;
        opacity: 1;
        }
    </style>
</head>
<body class="bg-swamp-50 min-h-screen relative">
    <div class="fixed inset-0 swamp-bg -z-10"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-swamp-50/90 to-swamp-100/60 z-0"></div>

    <div class="relative z-10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="text-center mb-16">
                <div class="flex items-center justify-center space-x-3 mb-6">
                    <img src="green-toad-logo.svg" alt="Greenswamp Logo" class="h-16 w-16">
                    <span class="text-4xl font-bold text-swamp-900">Greenswamp</span>
                </div>
                <p class="text-lg text-swamp-800">Welcome back to the pond</p>
            </div>

            <div class="max-w-md mx-auto bg-white rounded-2xl shadow-lg p-8 sm:p-12 border border-swamp-100">
                <form asp-controller="Account" asp-action="Login" method="post" class="space-y-8">
                    @Html.AntiForgeryToken()

                    <!-- Validation Summary (Model-only errors) -->
                    <div asp-validation-summary="ModelOnly" class="bg-red-50 border border-red-200 text-red-800 rounded-lg p-3 text-sm"></div>

                    <div class="space-y-2">
                        <label asp-for="Email" class="block text-base font-semibold text-swamp-900">Email</label>
                        <input asp-for="Email" type="email" required
                               class="mt-1 block w-full rounded-xl bg-white px-5 py-3.5
                        border border-swamp-200 focus:border-swamp-400
                        focus:ring-2 focus:ring-swamp-200 placeholder-slate-400
                        text-slate-900 shadow-sm"
                               placeholder="you@example.com">
                        <span asp-validation-for="Email" class="text-red-600 text-sm block"></span>
                    </div>

                    <div class="space-y-2">
                        <label asp-for="Password" class="block text-base font-semibold text-swamp-900">Password</label>
                        <input asp-for="Password" type="password" required
                               class="mt-1 block w-full rounded-xl bg-white px-5 py-3.5
                        border border-swamp-200 focus:border-swamp-400
                        focus:ring-2 focus:ring-swamp-200 placeholder-slate-400
                        text-slate-900 shadow-sm"
                               placeholder="••••••••">
                        <span asp-validation-for="Password" class="text-red-600 text-sm block"></span>
                    </div>

                    <div class="flex items-center justify-between">
                        <label class="flex items-center space-x-2 text-swamp-700 cursor-pointer">
                            <input asp-for="RememberMe" class="rounded border-swamp-300 text-swamp-600 focus:ring-swamp-400 cursor-pointer">
                            <span>Remember me</span>
                        </label>
                        <a href="#" class="text-swamp-700 hover:text-swamp-900 hover:underline text-sm">
                            Forgot password?
                        </a>
                    </div>

                    <button type="submit"
                            class="w-full bg-gradient-to-br from-swamp-500 to-swamp-600 text-white
                        py-4 px-6 rounded-xl hover:from-swamp-600 hover:to-swamp-700
                        focus:ring-2 focus:ring-swamp-400 font-semibold
                        transition-all duration-200 shadow-lg">
                        Log In
                    </button>

                    <p class="text-center text-swamp-700 mt-8">
                        New to Greenswamp?
                        <a asp-controller="Account" asp-action="Register" class="font-semibold text-swamp-800 hover:text-swamp-900 underline">
                            Create account
                        </a>
                    </p>
                </form>
            </div>

            <div class="mt-16 text-center">
                <div class="flex items-center justify-center space-x-4 text-swamp-700">
                    <a href="privacy.html" class="hover:text-swamp-900 hover:underline">Privacy</a>
                    <span class="text-swamp-500">•</span>
                    <a href="tos.html" class="hover:text-swamp-900 hover:underline">Terms</a>
                    <span class="text-swamp-500">•</span>
                    <a href="contact.html" class="hover:text-swamp-900 hover:underline">Contact</a>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>